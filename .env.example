# PostgreSQL — Neon (https://neon.tech)
# Use the direct (non-pooled) connection string — Prisma 7 handles pooling via its adapter
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/neondb?sslmode=require"

# JWT secrets — generate with: openssl rand -hex 64
JWT_SECRET="your-access-token-secret-here"
JWT_REFRESH_SECRET="your-refresh-token-secret-here"

# Stripe (https://dashboard.stripe.com)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Dev/staging bypass — set to "true" to show the payment skip button
# Never set this in production
NEXT_PUBLIC_ENABLE_DEV_BYPASS="false"
